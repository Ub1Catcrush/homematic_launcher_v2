<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Quelle 1: Webcam ────────────────────────────────────────────────── -->
    <PreferenceCategory android:title="@string/pref_category_motion_webcam">

        <SwitchPreferenceCompat
            android:key="motion_webcam_enabled"
            android:title="@string/pref_title_motion_webcam_enabled"
            android:summary="@string/pref_summary_motion_webcam_enabled"
            android:defaultValue="false"
            android:persistent="true" />

        <com.tvcs.homematic.SeekBarPreference
            android:key="motion_webcam_sensitivity"
            android:title="@string/pref_title_motion_sensitivity"
            android:summary="@string/pref_summary_motion_sensitivity_detail"
            android:defaultValue="8"
            android:persistent="true"
            android:dependency="motion_webcam_enabled" />

    </PreferenceCategory>

    <!-- ── Quelle 2: Gerätekamera ──────────────────────────────────────────── -->
    <PreferenceCategory android:title="@string/pref_category_motion_local">

        <SwitchPreferenceCompat
            android:key="motion_local_enabled"
            android:title="@string/pref_title_motion_local_enabled"
            android:summary="@string/pref_summary_motion_local_enabled"
            android:defaultValue="false"
            android:persistent="true" />

        <ListPreference
            android:key="motion_local_facing"
            android:title="@string/pref_title_motion_local_facing"
            android:entries="@array/motion_facing_entries"
            android:entryValues="@array/motion_facing_values"
            android:defaultValue="front"
            android:persistent="true"
            android:dependency="motion_local_enabled" />

        <com.tvcs.homematic.SeekBarPreference
            android:key="motion_local_sensitivity"
            android:title="@string/pref_title_motion_sensitivity"
            android:summary="@string/pref_summary_motion_sensitivity_detail"
            android:defaultValue="8"
            android:persistent="true"
            android:dependency="motion_local_enabled" />

    </PreferenceCategory>

    <!-- ── Bildschirm wecken ───────────────────────────────────────────────── -->
    <PreferenceCategory android:title="@string/pref_category_motion_wake">

        <com.tvcs.homematic.SeekBarPreference
            android:key="motion_wake_timeout_sec"
            android:title="@string/pref_title_motion_wake_timeout"
            android:summary="@string/pref_summary_motion_wake_timeout_detail"
            android:defaultValue="60"
            android:persistent="true" />

    </PreferenceCategory>

    <!-- ── Erkennungsbereich (ROI) ─────────────────────────────────────────── -->
    <PreferenceCategory android:title="@string/pref_category_motion_roi">

        <com.tvcs.homematic.RoiPickerPreference
            android:key="motion_roi"
            android:title="@string/pref_title_motion_roi"
            android:summary="@string/roi_full_frame"
            android:defaultValue=""
            android:persistent="true" />

    </PreferenceCategory>

    <!-- ── Aktivzeiten ─────────────────────────────────────────────────────── -->
    <PreferenceCategory android:title="@string/pref_category_motion_schedule">

        <EditTextPreference
            android:key="motion_time_start"
            android:title="@string/pref_title_motion_time_start"
            android:summary="@string/pref_summary_motion_schedule"
            android:defaultValue=""
            android:persistent="true"
            android:inputType="time" />

        <EditTextPreference
            android:key="motion_time_end"
            android:title="@string/pref_title_motion_time_end"
            android:summary="@string/pref_summary_motion_schedule"
            android:defaultValue=""
            android:persistent="true"
            android:inputType="time" />

    </PreferenceCategory>

    <!-- ── Feineinstellung (Experte) ──────────────────────────────────────── -->
    <PreferenceCategory android:title="@string/pref_category_motion_expert">

        <com.tvcs.homematic.SeekBarPreference
            android:key="motion_luma_threshold"
            android:title="@string/pref_title_motion_luma_threshold"
            android:summary="@string/pref_summary_motion_luma_detail"
            android:defaultValue="20"
            android:persistent="true" />

        <com.tvcs.homematic.SeekBarPreference
            android:key="motion_cooldown_sec"
            android:title="@string/pref_title_motion_cooldown"
            android:summary="@string/pref_summary_motion_cooldown_detail"
            android:defaultValue="2"
            android:persistent="true" />

        <com.tvcs.homematic.SeekBarPreference
            android:key="motion_interval_sec"
            android:title="@string/pref_title_motion_interval"
            android:summary="@string/pref_summary_motion_interval_detail"
            android:defaultValue="1"
            android:persistent="true" />

        <com.tvcs.homematic.SeekBarPreference
            android:key="motion_adaptation_rate"
            android:title="@string/pref_title_motion_adaptation"
            android:summary="@string/pref_summary_motion_adaptation_detail"
            android:defaultValue="5"
            android:persistent="true" />

    </PreferenceCategory>

    <!-- ── Nacht-Dimmen ────────────────────────────────────────────────────── -->
    <PreferenceCategory android:title="@string/pref_category_night_dim">

        <SwitchPreferenceCompat
            android:key="night_dim_enabled"
            android:title="@string/pref_title_night_dim_enabled"
            android:summary="@string/pref_summary_night_dim_enabled"
            android:defaultValue="false"
            android:persistent="true" />

        <EditTextPreference
            android:key="night_dim_start"
            android:title="@string/pref_title_night_dim_start"
            android:summary="@string/pref_summary_night_dim_time"
            android:defaultValue="22:00"
            android:persistent="true"
            android:inputType="time"
            android:dependency="night_dim_enabled" />

        <EditTextPreference
            android:key="night_dim_end"
            android:title="@string/pref_title_night_dim_end"
            android:summary="@string/pref_summary_night_dim_time"
            android:defaultValue="07:00"
            android:persistent="true"
            android:inputType="time"
            android:dependency="night_dim_enabled" />

        <com.tvcs.homematic.SeekBarPreference
            android:key="night_dim_brightness"
            android:title="@string/pref_title_night_dim_brightness"
            android:summary="@string/pref_summary_night_dim_brightness_detail"
            android:defaultValue="5"
            android:persistent="true"
            android:dependency="night_dim_enabled" />

    </PreferenceCategory>

</PreferenceScreen>
