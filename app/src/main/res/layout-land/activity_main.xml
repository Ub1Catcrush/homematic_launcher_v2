<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- AppBar — compact in landscape -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/AppTheme.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:minHeight="36dp"
            android:background="?attr/colorPrimary"
            app:contentInsetStart="6dp"
            app:contentInsetEnd="6dp"
            app:popupTheme="@style/AppTheme.PopupOverlay" />

        <TextView
            android:id="@+id/status_text"
                    android:maxLines="1"
                    android:ellipsize="end"
            android:layout_width="match_parent"
            android:layout_height="13dp"
            android:textSize="8sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical"
            android:background="@color/status_bar_bg"
            android:textColor="@android:color/white"
            android:text="@string/status_initializing" />

        <ProgressBar
            android:id="@+id/loading_indicator"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:indeterminate="true"
            android:progressTint="@color/colorAccent"
            android:visibility="gone" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main content: vertical stack -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- TOP: Room grid fills all space above bottom strip -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/grid_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FF000000" />

        <!-- BOTTOM: DB Transit (left) + Camera (right) side by side -->
        <LinearLayout
            android:id="@+id/bottom_strip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- DB Transit panel -->
            <LinearLayout
                android:id="@+id/transit_panel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#CC001122"
                android:visibility="gone">

                <TextView
                    android:id="@+id/transit_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="#AAFFFFFF"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="1dp"
                    android:text="" />

                <LinearLayout
                    android:id="@+id/transit_row_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

                <LinearLayout
                    android:id="@+id/transit_row_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

                <LinearLayout
                    android:id="@+id/transit_row_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

                <TextView
                    android:id="@+id/transit_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="#FFFF6666"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:visibility="gone"
                    android:text="" />

            </LinearLayout>

            <!-- Camera panel -->
            <LinearLayout
                android:id="@+id/camera_panel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#CC000000"
                android:visibility="gone">

                <!-- Status row: label left, mute button right -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/camera_status_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="9sp"
                        android:textColor="#AAFFFFFF"
                        android:paddingStart="6dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="1dp"
                        android:text="" />

                    <ImageButton
                        android:id="@+id/camera_mute_button"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_lock_silent_mode_off"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/camera_mute_desc"
                        android:visibility="gone"
                        android:tint="#AAFFFFFF"
                        android:padding="4dp" />

                </LinearLayout>

                <androidx.media3.ui.PlayerView
                    android:id="@+id/camera_player_view"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:visibility="gone"
                    app:use_controller="false"
                    app:resize_mode="fixed_width" />

                <ImageView
                    android:id="@+id/camera_snapshot_view"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@string/camera_snapshot_desc" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
