<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- AppBar: Toolbar + status strip + progress bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/AppTheme.AppBarOverlay"
        android:tag="appbar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:minHeight="42dp"
            android:background="?attr/colorPrimary"
            app:contentInsetStart="6dp"
            app:contentInsetEnd="6dp"
            app:popupTheme="@style/AppTheme.PopupOverlay" />

        <TextView
            android:id="@+id/status_text"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:textSize="9sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical"
            android:background="@color/status_bar_bg"
            android:textColor="@android:color/white"
            android:text="@string/status_initializing" />

        <ProgressBar
            android:id="@+id/loading_indicator"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:indeterminate="true"
            android:progressTint="@color/colorAccent"
            android:visibility="gone" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main content: grid scrolls, camera panel sticks to bottom -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:tag="main_content">

        <!-- Transit panel — above camera panel -->
        <LinearLayout
            android:id="@+id/transit_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC001122"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/camera_panel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/transit_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#AAFFFFFF"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="1dp"
                android:text="" />
            <!-- Transit rows are added programmatically (scrollable, count configurable) -->

            <TextView
                android:id="@+id/transit_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#FFFF6666"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone"
                android:text="" />

        </LinearLayout>

        <!-- Camera panel — FrameLayout so the status strip floats OVER the video -->
        <FrameLayout
            android:id="@+id/camera_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ExoPlayer surface for RTSP — full size of frame -->
            <androidx.media3.ui.PlayerView
                android:id="@+id/camera_player_view"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:visibility="gone"
                app:use_controller="false"
                app:resize_mode="fixed_width" />

            <!-- ImageView for MJPEG snapshot fallback — full size of frame -->
            <ImageView
                android:id="@+id/camera_snapshot_view"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="@string/camera_snapshot_desc" />

            <!-- Status row: floats at the TOP of the frame, over the video -->
            <LinearLayout
                android:id="@+id/camera_status_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#99000000">

                <TextView
                    android:id="@+id/camera_status_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="10sp"
                    android:textColor="#FFFFFFFF"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="" />

                <ImageButton
                    android:id="@+id/camera_mute_button"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/camera_mute_desc"
                    android:visibility="gone"
                    android:padding="6dp"
                    app:tint="#FFFFFFFF" />

            </LinearLayout>

        </FrameLayout>

        <!-- Room grid — constrained above the camera panel when visible -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/grid_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#FF000000"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/transit_panel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
